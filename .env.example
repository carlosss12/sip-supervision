# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DATABASE_URL="postgresql://sip_user:sip_pass@db:5432/sip_db"

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
JWT_SECRET="cambia_esto_por_una_clave_secreta_larga_y_segura"

# ── Servidor backend ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
TZ=America/Santiago

# ── NVR Hikvision (camaras de seguridad) ─────────────────────────────────────
NVR_IP=IP_DEL_NVR
NVR_PORT=PUERTO_DEL_NVR
NVR_USER=admin
NVR_PASS=CONTRASENA_DEL_NVR
