cat > .gitignore << 'EOF'
# Dependencias
node_modules/
backend/node_modules/
frontend/node_modules/

# Build
backend/dist/
frontend/dist/

# Variables de entorno (nunca subir al repo)
.env
backend/.env
frontend/.env

# Docker volumes
sip_pgdata/

# Logs
*.log
npm-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db

# VS Code
.vscode/
EOF